# Ensure consistent line endings and text file normalization
* text=auto

# Arduino sketches and source files
*.ino  text eol=lf
*.cpp  text eol=lf
*.h    text eol=lf
*.c    text eol=lf
*.hpp  text eol=lf

# PlatformIO and config files
*.ini  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yml  text eol=lf

# Binary files (do not modify line endings)
*.jpg  binary
*.png  binary
*.gif  binary
*.pdf  binary
*.bin  binary
*.zip  binary
*.exe  binary